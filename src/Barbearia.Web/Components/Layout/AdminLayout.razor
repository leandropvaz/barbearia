@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS

<!-- Overlay para fechar sidebar no mobile -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="admin-layout">
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <img src="/images/logo.jpeg" alt="Logo"
                 style="width:160px;height:160px;object-fit:contain;display:block;margin:0 auto 6px;mix-blend-mode:screen;"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
            <div style="display:none">
                <span class="brand-icon">✂</span>
                <span class="brand-name">BarberShop</span>
            </div>
            <span class="brand-sub">Painel Admin</span>
        </div>

        <nav class="sidebar-nav" onclick="closeSidebarOnMobile()">
            <div class="nav-section-title">Visão Geral</div>
            <NavLink class="nav-link" href="/admin" Match="NavLinkMatch.All">
                <span class="nav-icon">📊</span> Dashboard
            </NavLink>

            <div class="nav-section-title">Gestão</div>
            <NavLink class="nav-link" href="/admin/barbeiros">
                <span class="nav-icon">💈</span> Barbeiros
            </NavLink>
            <NavLink class="nav-link" href="/admin/servicos">
                <span class="nav-icon">✂</span> Serviços
            </NavLink>

            <div class="nav-section-title">Agenda</div>
            <NavLink class="nav-link" href="/admin/reservas">
                <span class="nav-icon">📅</span> Reservas
            </NavLink>
            <NavLink class="nav-link" href="/admin/agenda">
                <span class="nav-icon">🕐</span> Horários
            </NavLink>
            <NavLink class="nav-link" href="/barbeiro/agenda">
                <span class="nav-icon">📋</span> A Minha Agenda
            </NavLink>

            <hr class="divider" />
            <NavLink class="nav-link" href="/" target="_blank">
                <span class="nav-icon">🌐</span> Ver Site de Clientes
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <a href="/admin/logout" class="btn btn-danger btn-full btn-sm">
                ← Sair
            </a>
        </div>
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <button class="btn btn-secondary btn-sm" style="min-width:44px;"
                    onclick="toggleSidebar()">☰</button>

            <div class="topbar-logo">
                <img src="/images/logo.jpeg" alt="Logo" style="height:40px;object-fit:contain;mix-blend-mode:screen;"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
                <span style="display:none;font-size:16px;font-weight:700;color:var(--gold);letter-spacing:1px;">BarberShop</span>
            </div>

            <div style="display:flex;align-items:center;gap:12px;">
                <AuthorizeView>
                    <Authorized>
                        <span style="font-size:13px;color:var(--text-secondary);">@context.User.Identity?.Name</span>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="admin-content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">✕</span>
</div>

<script>
    function toggleSidebar() {
        var sidebar = document.getElementById('adminSidebar');
        var overlay = document.getElementById('sidebarOverlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
    }
    function closeSidebar() {
        document.getElementById('adminSidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('open');
    }
    function closeSidebarOnMobile() {
        if (window.innerWidth <= 768) closeSidebar();
    }
</script>
