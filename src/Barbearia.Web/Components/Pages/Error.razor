@page "/Error"
@using System.Diagnostics
@layout Layout.MainLayout

<PageTitle>Erro</PageTitle>

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg-primary);">
    <div style="text-align:center;padding:40px;">
        <div style="font-size:60px;margin-bottom:16px;">⚠</div>
        <h1 style="color:var(--gold);">Ops! Algo deu errado.</h1>
        <p style="color:var(--text-muted);margin:12px 0;">
            Ocorreu um erro ao processar sua solicitação.
            @if (ShowRequestId)
            {
                <span>ID: <code>@RequestId</code></span>
            }
        </p>
        <a href="/" class="btn btn-primary" style="margin-top:16px;display:inline-flex;">← Voltar ao Início</a>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
