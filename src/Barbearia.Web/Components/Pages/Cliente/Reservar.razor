@* @page "/" *@
@page "/reservar"
@layout Layout.MainLayout
@rendermode InteractiveServer
@inject IBarbeiroService BarbeiroService
@inject IServicoService ServicoService
@inject IReservaService ReservaService
@inject NavigationManager Nav

<PageTitle>BarberShop - Faça a sua Marcação</PageTitle>

<div style="background:var(--bg-primary);min-height:100vh;">
    <div class="booking-container">

        <!-- HEADER -->
        <div class="booking-header">
            <img src="/images/logo.jpeg" alt="Logo"
                 style="width:180px;height:180px;object-fit:contain;display:block;margin:0 auto 8px;mix-blend-mode:screen;" />
            <span class="logo-sub">Marque o seu horário</span>
        </div>

        <!-- STEPS -->
        <div class="steps-bar">
            <div class="step-item @GetStepClass(1)">
                <div class="step-circle">@(Passo > 1 ? "✓" : "1")</div>
                <span class="step-label">Barbeiro</span>
            </div>
            <div class="step-item @GetStepClass(2)">
                <div class="step-circle">@(Passo > 2 ? "✓" : "2")</div>
                <span class="step-label">Serviço</span>
            </div>
            <div class="step-item @GetStepClass(3)">
                <div class="step-circle">@(Passo > 3 ? "✓" : "3")</div>
                <span class="step-label">Data/Hora</span>
            </div>
            <div class="step-item @GetStepClass(4)">
                <div class="step-circle">@(Passo > 4 ? "✓" : "4")</div>
                <span class="step-label">Dados</span>
            </div>
        </div>

        @if (_mensagemErro != null)
        {
            <div class="alert alert-danger">⚠ @_mensagemErro</div>
        }

        <!-- PASSO 1: BARBEIRO -->
        @if (Passo == 1)
        {
            <div class="card">
                <h2 class="booking-section-title">👤 Escolha o Barbeiro</h2>
                @if (_carregando)
                {
                    <div class="loading-overlay"><div class="spinner"></div></div>
                }
                else if (!_barbeiros.Any())
                {
                    <div style="text-align:center;padding:30px;color:var(--text-muted);">
                        Nenhum barbeiro disponível de momento.
                    </div>
                }
                else
                {
                    <div class="grid grid-auto">
                        @foreach (var b in _barbeiros)
                        {
                            <div class="barber-card" style="cursor:pointer;@(_barbeiroId == b.Id ? "border-color:var(--gold);background:rgba(201,150,63,0.08);" : "")"
                                 @onclick="() => SelecionarBarbeiro(b)">
                                <div class="barber-status">
                                    <span class="status-dot @(b.AgendaAberta ? "online" : "offline")"></span>
                                </div>
                                @if (!string.IsNullOrEmpty(b.FotoUrl))
                                {
                                    <img src="@b.FotoUrl" class="barber-avatar" />
                                }
                                else
                                {
                                    <div class="barber-avatar-placeholder">👤</div>
                                }
                                <div class="barber-name">@b.Nome</div>
                                <div style="font-size:12px;color:var(--text-muted);">
                                    @b.BarbeiroServicos.Count serviço(s)
                                </div>
                                @if (!b.AgendaAberta)
                                {
                                    <span class="badge badge-danger" style="margin-top:8px;">Indisponível</span>
                                }
                                else
                                {
                                    <span class="badge badge-success" style="margin-top:8px;">Disponível</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- PASSO 2: SERVIÇO -->
        @if (Passo == 2)
        {
            <div class="card">
                <h2 class="booking-section-title">✂ Escolha o Serviço</h2>
                @foreach (var s in _servicos)
                {
                    <div class="service-option @(_servicoId == s.Id ? "selected" : "")"
                         @onclick="() => SelecionarServico(s)">
                        <div class="service-info">
                            <div class="service-name">@s.Nome</div>
                            <div class="service-details">⏱ @s.DuracaoMinutos min @(s.Descricao != null ? "· " + s.Descricao : "")</div>
                        </div>
                        <div class="service-price">€@s.Preco.ToString("F2")</div>
                        @if (_servicoId == s.Id)
                        {
                            <span style="color:var(--gold);font-size:20px;">✓</span>
                        }
                    </div>
                }
            </div>
            <button class="btn btn-secondary mt-4" @onclick="() => Passo = 1">← Voltar</button>
        }

        <!-- PASSO 3: DATA E HORA -->
        @if (Passo == 3)
        {
            <div class="card">
                <h2 class="booking-section-title">📅 Escolha a Data</h2>

                <div class="date-picker-row">
                    @foreach (var d in _diasDisponiveis)
                    {
                        <div class="date-pill @(_dataEscolhida.Date == d.Date ? "selected" : "")"
                             @onclick="() => SelecionarData(d)">
                            <span class="day-name">@d.ToString("ddd")</span>
                            <span class="day-number">@d.Day</span>
                            <span class="month-name">@d.ToString("MMM")</span>
                        </div>
                    }
                </div>

                @if (_carregandoHorarios)
                {
                    <div class="loading-overlay"><div class="spinner"></div></div>
                }
                else if (_horariosDisponiveis.Any())
                {
                    <h3 class="booking-section-title" style="font-size:15px;margin-top:16px;">🕐 Horários Disponíveis</h3>
                    <div class="slot-grid">
                        @foreach (var h in _horariosDisponiveis)
                        {
                            <div class="time-slot @(_horaEscolhida == h ? "selected" : "")"
                                 @onclick="() => SelecionarHorario(h)">
                                @h.ToString("HH:mm")
                            </div>
                        }
                    </div>
                }
                else if (_dataEscolhida != default)
                {
                    <p style="text-align:center;color:var(--text-muted);padding:20px;">
                        Nenhum horário disponível nesta data. Escolha outro dia.
                    </p>
                }
            </div>

            <div style="display:flex;gap:12px;margin-top:16px;">
                <button class="btn btn-secondary" @onclick="() => Passo = 2">← Voltar</button>
                @if (_horaEscolhida != default)
                {
                    <button class="btn btn-primary" @onclick="() => Passo = 4">Continuar →</button>
                }
            </div>
        }

        <!-- PASSO 4: DADOS DO CLIENTE -->
        @if (Passo == 4)
        {
            <div class="card">
                <h2 class="booking-section-title">📋 Seus Dados</h2>

                <div style="background:var(--bg-secondary);border-radius:8px;padding:16px;margin-bottom:20px;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                        <span style="color:var(--text-muted);">Barbeiro</span>
                        <strong>@_barbeiroBarbeiro?.Nome</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                        <span style="color:var(--text-muted);">Serviço</span>
                        <strong>@_servicoEscolhido?.Nome</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;">
                        <span style="color:var(--text-muted);">Data/Hora</span>
                        <strong>@_horaEscolhida.ToString("dd/MM/yyyy") às @_horaEscolhida.ToString("HH:mm")</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--text-muted);">Valor</span>
                        <strong style="color:var(--gold);">€@_servicoEscolhido?.Preco.ToString("F2")</strong>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Nome Completo *</label>
                    <input @bind="_clienteNome" class="form-control" placeholder="O seu nome" />
                </div>
                <div class="form-group">
                    <label class="form-label">Telemóvel / WhatsApp *</label>
                    <input @bind="_clienteTelefone" class="form-control" placeholder="912 345 678" />
                </div>
                <div class="form-group">
                    <label class="form-label">E-mail *</label>
                    <input @bind="_clienteEmail" type="email" class="form-control" placeholder="seu@email.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">Observações (opcional)</label>
                    <input @bind="_observacoes" class="form-control" placeholder="Ex: Cabelo médio, trazer referência..." />
                </div>
            </div>

            <div style="display:flex;gap:12px;margin-top:16px;">
                <button class="btn btn-secondary" @onclick="() => Passo = 3">← Voltar</button>
                <button class="btn btn-primary btn-lg" @onclick="Confirmar" disabled="@_confirmando" style="flex:1;">
                    @if (_confirmando)
                    {
                        <span class="spinner-sm"></span>
                        <span>Confirmando...</span>
                    }
                    else
                    {
                        <span>✓ Confirmar Marcação</span>
                    }
                </button>
            </div>
        }

        <!-- PASSO 5: SUCESSO -->
        @if (Passo == 5 && _reservaCriada != null)
        {
            <div class="success-screen">
                <span class="success-icon">🎉</span>
                <h2 style="font-size:24px;margin-bottom:8px;">Marcação Confirmada!</h2>
                <p style="color:var(--text-secondary);">Receberá a confirmação por e-mail e WhatsApp</p>

                <div class="confirmation-code">
                    <div class="code-label">Código de Confirmação</div>
                    <div class="code-value">@_reservaCriada.CodigoConfirmacao</div>
                    <div class="code-hint">Guarde este código para alterar ou cancelar a marcação</div>
                </div>

                <div style="background:var(--bg-secondary);border-radius:10px;padding:20px;text-align:left;margin-bottom:24px;">
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                        <span style="color:var(--text-muted);">Barbeiro</span>
                        <strong>@_reservaCriada.Barbeiro?.Nome</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                        <span style="color:var(--text-muted);">Serviço</span>
                        <strong>@_reservaCriada.Servico?.Nome</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-bottom:8px;">
                        <span style="color:var(--text-muted);">Data/Hora</span>
                        <strong>@_reservaCriada.DataHora.ToString("dd/MM/yyyy 'às' HH:mm")</strong>
                    </div>
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--text-muted);">Valor</span>
                        <strong style="color:var(--gold);">€@_reservaCriada.Servico?.Preco.ToString("F2")</strong>
                    </div>
                </div>

                <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
                    <button class="btn btn-outline" @onclick="NovaReserva">+ Nova Marcação</button>
                    <a href="/minha-reserva/@_reservaCriada.CodigoConfirmacao" class="btn btn-secondary">
                        ✏ Gerir Marcação
                    </a>
                </div>
            </div>
        }

        <!-- RODAPÉ CLIENTE -->
        <div style="text-align:center;padding:24px;margin-top:20px;border-top:1px solid var(--border);">
            <a href="/minha-reserva" style="font-size:14px;color:var(--text-muted);">
                🔍 Já tem um código? Gerir a minha marcação →
            </a>
        </div>
    </div>
</div>

@code {
    private int Passo = 1;
    private bool _carregando = true, _carregandoHorarios = false, _confirmando = false;
    private string? _mensagemErro;

    private List<Barbeiro> _barbeiros = new();
    private List<Servico> _servicos = new();
    private List<DateTime> _horariosDisponiveis = new();
    private List<DateTime> _diasDisponiveis = new();

    private int _barbeiroId, _servicoId;
    private Barbeiro? _barbeiroBarbeiro;
    private Servico? _servicoEscolhido;
    private DateTime _dataEscolhida = DateTime.Today;
    private DateTime _horaEscolhida;
    private Reserva? _reservaCriada;

    private string _clienteNome = "", _clienteEmail = "", _clienteTelefone = "", _observacoes = "";

    protected override async Task OnInitializedAsync()
    {
        _barbeiros = await BarbeiroService.ListarTodosAsync(true);
        _barbeiros = _barbeiros.Where(b => b.AgendaAberta).ToList();

        // Build 15-day date range
        _diasDisponiveis = Enumerable.Range(0, 15)
            .Select(i => DateTime.Today.AddDays(i))
            .Where(d => d.DayOfWeek != DayOfWeek.Sunday)
            .ToList();

        _carregando = false;
    }

    async Task SelecionarBarbeiro(Barbeiro b)
    {
        if (!b.AgendaAberta) return;
        _barbeiroId = b.Id;
        _barbeiroBarbeiro = b;
        _servicos = await ServicoService.ListarPorBarbeiroAsync(b.Id);
        Passo = 2;
    }

    async Task SelecionarServico(Servico s)
    {
        _servicoId = s.Id;
        _servicoEscolhido = s;
        await SelecionarData(_diasDisponiveis.First());
        Passo = 3;
    }

    async Task SelecionarData(DateTime d)
    {
        _dataEscolhida = d;
        _horaEscolhida = default;
        _carregandoHorarios = true;
        _horariosDisponiveis = await ReservaService.ObterHorariosDisponiveisAsync(_barbeiroId, _servicoId, d);
        _carregandoHorarios = false;
    }

    void SelecionarHorario(DateTime h) => _horaEscolhida = h;

    async Task Confirmar()
    {
        _mensagemErro = null;

        if (string.IsNullOrWhiteSpace(_clienteNome)) { _mensagemErro = "O nome é obrigatório."; return; }
        if (string.IsNullOrWhiteSpace(_clienteTelefone)) { _mensagemErro = "O telemóvel é obrigatório."; return; }
        if (string.IsNullOrWhiteSpace(_clienteEmail) || !_clienteEmail.Contains('@')) { _mensagemErro = "E-mail inválido."; return; }

        _confirmando = true;
        try
        {
            var reserva = new Reserva
            {
                BarbeiroId = _barbeiroId,
                ServicoId = _servicoId,
                ClienteNome = _clienteNome.Trim(),
                ClienteEmail = _clienteEmail.Trim().ToLower(),
                ClienteTelefone = _clienteTelefone.Trim(),
                DataHora = _horaEscolhida,
                Observacoes = _observacoes
            };

            _reservaCriada = await ReservaService.CriarAsync(reserva);
            Passo = 5;
        }
        catch (Exception ex)
        {
            _mensagemErro = ex.Message;
        }
        finally { _confirmando = false; }
    }

    void NovaReserva()
    {
        Passo = 1;
        _barbeiroId = 0;
        _servicoId = 0;
        _clienteNome = _clienteEmail = _clienteTelefone = _observacoes = "";
        _horaEscolhida = default;
        _reservaCriada = null;
        _mensagemErro = null;
    }

    string GetStepClass(int step)
    {
        if (Passo > step) return "done";
        if (Passo == step) return "active";
        return "";
    }
}
